{
  "name": "healthcare-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo para o aplicativo HealthCare, incluindo o front-end e o back-end.",
  "scripts": {
    "start": "concurrently \"npm:start:frontend\" \"npm:start:backend\"",
    "start:frontend": "npm start --workspace=front-end",
    "start:backend": "npm run dev --workspace=back-end",
    "install:all": "npm install"
  },
  "workspaces": [
    "front-end",
    "back-end"
  ],
  "devDependencies": {
    "@types/react": "~19.0.10",
    "concurrently": "^8.2.2",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "expo": "^53.0.11",
    "expo-router": "^5.1.0"
  }
}
